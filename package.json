{
  "name": "runjucks",
  "version": "0.1.0",
  "description": "Rust-powered Nunjucks-compatible template engine (Node.js native addon)",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "keywords": [
    "nunjucks",
    "templates",
    "napi-rs",
    "rust",
    "node-addon"
  ],
  "files": [
    "index.js",
    "index.d.ts",
    "browser.js",
    "*.node"
  ],
  "napi": {
    "binaryName": "runjucks",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl"
    ]
  },
  "engines": {
    "node": ">= 18"
  },
  "scripts": {
    "build": "napi build --platform --release --manifest-path native/Cargo.toml --output-dir .",
    "build:debug": "napi build --platform --manifest-path native/Cargo.toml --output-dir .",
    "test": "node --test __test__/*.test.mjs",
    "test:pending": "node --test __test__/interpolation-pending.mjs",
    "test:rust": "cargo test --manifest-path native/Cargo.toml",
    "rust:test": "npm run test:rust",
    "test:rust:green": "cargo test --manifest-path native/Cargo.toml --test environment --test errors --test filters --test lexer --test parser --test renderer --test value"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.2.0"
  }
}
