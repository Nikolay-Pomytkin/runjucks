{
  "name": "@zneep/runjucks",
  "version": "0.1.4",
  "description": "Rust-powered Nunjucks-compatible template engine (Node.js native addon)",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nikolay-Pomytkin/runjucks.git"
  },
  "keywords": [
    "nunjucks",
    "templates",
    "napi-rs",
    "rust",
    "node-addon"
  ],
  "files": [
    "index.js",
    "index.d.ts",
    "browser.js",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "napi": {
    "binaryName": "runjucks",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl"
    ]
  },
  "engines": {
    "node": ">= 18"
  },
  "scripts": {
    "build": "napi build --platform --release --manifest-path native/crates/runjucks-napi/Cargo.toml --output-dir .",
    "build:binding": "napi build --platform --release --no-js --manifest-path native/crates/runjucks-napi/Cargo.toml --output-dir .",
    "build:debug": "napi build --platform --manifest-path native/crates/runjucks-napi/Cargo.toml --output-dir .",
    "napi:artifacts": "napi artifacts --output-dir artifacts --npm-dir npm",
    "napi:prepublish": "napi pre-publish -p npm --tag-style npm --no-gh-release",
    "test": "node --test __test__/*.test.mjs __test__/conformance/run.mjs",
    "test:conformance:node": "node --test __test__/conformance/run.mjs",
    "test:conformance:rust": "cargo test --manifest-path native/Cargo.toml --test conformance",
    "test:pending": "node --test __test__/interpolation-pending.mjs",
    "test:rust": "cargo test --manifest-path native/Cargo.toml",
    "rust:test": "npm run test:rust",
    "test:rust:green": "cargo test --manifest-path native/Cargo.toml --test environment --test errors --test filters --test lexer --test parser --test renderer --test value",
    "docs:dev": "npm run dev --prefix docs",
    "docs:build": "npm run build --prefix docs",
    "docs:preview": "npm run preview --prefix docs",
    "perf": "node perf/run.mjs",
    "perf:json": "node perf/run.mjs --json"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.2.0",
    "nunjucks": "3.2.4",
    "tinybench": "6.0.0"
  },
  "optionalDependencies": {
    "@zneep/runjucks-win32-x64-msvc": "0.1.4",
    "@zneep/runjucks-darwin-x64": "0.1.4",
    "@zneep/runjucks-darwin-arm64": "0.1.4",
    "@zneep/runjucks-linux-x64-gnu": "0.1.4",
    "@zneep/runjucks-linux-x64-musl": "0.1.4",
    "@zneep/runjucks-linux-arm64-gnu": "0.1.4",
    "@zneep/runjucks-linux-arm64-musl": "0.1.4"
  }
}