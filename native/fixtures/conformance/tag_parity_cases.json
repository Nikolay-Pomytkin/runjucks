  },
  {
    "id": "tag_custom_delimiters_var",
    "source": "nunjucks custom tags",
    "template": "Hello <$ name $>!",
    "context": { "name": "World" },
    "env": {
      "tags": {
        "blockStart": "<%",
        "blockEnd": "%>",
        "variableStart": "<$",
        "variableEnd": "$>",
        "commentStart": "<#",
        "commentEnd": "#>"
      }
    },
    "expected": "Hello World!"
  },
  {
    "id": "tag_custom_delimiters_block",
