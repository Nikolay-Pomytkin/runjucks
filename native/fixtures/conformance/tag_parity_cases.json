  {
    "id": "tag_import_top_level_set",
    "source": "nunjucks import namespace top-level set",
    "template": "{% import \"lib.njk\" as lib %}{{ lib.exported }}",
    "context": {},
    "env": {
      "templateMap": {
        "lib.njk": "{% set exported = 42 %}"
      }
    },
    "expected": "42"
  },
  {
    "id": "tag_import_with_context_macro",
    "source": "nunjucks import with context for module scope",
    "template": "{% import \"lib.njk\" as lib with context %}{{ lib.m() }}",
    "context": { "ctxval": 42 },
    "env": {
      "templateMap": {
        "lib.njk": "{% set x = ctxval %}{% macro m() %}{{ x }}{% endmacro %}"
      }
    },
    "expected": "42"
  },
  {
    "id": "tag_import_without_context_macro",
