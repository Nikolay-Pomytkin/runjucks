    "env": {
      "tags": {
        "blockStart": "<%",
        "blockEnd": "%>",
        "variableStart": "<$",
        "variableEnd": "$>",
        "commentStart": "<#",
        "commentEnd": "#>"
      }
    },
    "expected": "yes"
  },
