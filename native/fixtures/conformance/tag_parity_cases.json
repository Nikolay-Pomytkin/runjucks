    "context": {},
    "expected": "Hello Ada"
  },
  {
    "id": "tag_filter_block_upper",
    "source": "nunjucks filter block",
    "template": "{% filter upper %}ab{% endfilter %}",
    "context": {},
    "expected": "AB"
  },
  {
    "id": "tag_switch_case1_only",
    "source": "nunjucks switch fall-through",
    "template": "{% switch 1 %}{% case 1 %}A{% case 2 %}B{% default %}Z{% endswitch %}",
    "context": {},
    "expected": "A"
  },
  {
    "id": "tag_for_loop_builtins",
    "source": "nunjucks loop.*",
    "template": "{% for i in [10,20] %}{{ loop.index }}:{{ loop.index0 }}:{{ loop.first }};{% endfor %}",
    "context": {},
    "expected": "1:0:true;2:1:false;"
  },
  {
    "id": "tag_call_macro_caller",
    "source": "nunjucks call/caller",
    "template": "{% macro wrap() %}<div>{{ caller() }}</div>{% endmacro %}{% call wrap() %}in{% endcall %}",
    "context": {},
    "expected": "<div>in</div>"
  },
  {
    "id": "tag_call_caller_positional_args",
    "source": "nunjucks compiler.js caller() with call(item) signature",
    "template": "{% macro list(items) %}<ul>{% for i in items %}<li>{{ caller(i) }}</li>{% endfor %}</ul>{% endmacro %}{% call(item) list([\"a\",\"b\"]) %}{{ item }}{% endcall %}",
    "context": {},
    "expected": "<ul><li>a</li><li>b</li></ul>"
  },
  {
    "id": "tag_macro_defaults_kwargs",
    "source": "nunjucks macro default + keyword args",
    "template": "{% macro m(a, b=1) %}{{ a }},{{ b }}{% endmacro %}{{ m(2) }},{{ m(2, b=3) }}",
    "context": {},
    "expected": "2,1,2,3"
  },
  {
    "id": "tag_include_from_map",
    "source": "nunjucks include + template map",
    "template": "{% include \"part.njk\" %}",
    "context": { "x": "y" },
    "env": {
      "templateMap": {
        "part.njk": "Hello {{ x }}"
      }
    },
    "expected": "Hello y"
  },
  {
    "id": "tag_extends_layout_map",
    "source": "nunjucks extends + template map",
    "template": "{% extends \"layout.njk\" %}{% block main %}Hi{% endblock %}",
    "context": {},
    "env": {
      "templateMap": {
        "layout.njk": "LAYOUT:{% block main %}{% endblock %}:END"
      }
    },
    "expected": "LAYOUT:Hi:END"
  },
  {
    "id": "tag_trim_blocks_if",
    "source": "nunjucks trimBlocks",
